layout {
    cwd "/home/jgatkinsn"
    tab name=".DOTFILES" focus=true hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="vertical" {
            pane cwd=".dotfiles" size="50%"
            pane command="zellij" cwd=".dotfiles" focus=true size="50%" {
                args "action" "dump-layout"
                start_suspended true
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="BTOP" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="btop" cwd="/home/jgatkinsn" {
            start_suspended true
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="NVTOP" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="nvtop" cwd="/home/jgatkinsn" {
            start_suspended true
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="RUSTLINGS" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane command="rustlings" cwd="/home/jgatkinsn/projects/rust/rustlings" size="50%" {
            start_suspended true
        }
        pane command="nvim" cwd="/home/jgatkinsn/projects/rust/rustlings" size="50%" {
            start_suspended true
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="HOME" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="MC_PY" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="vertical" {
            pane cwd="projects/marvelchamppy" size="50%"
            pane edit="/home/jgatkinsn/.config/zellij/config.kdl" cwd="projects/marvelchamppy" size="50%"
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="OBSIDIAN" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="vertical" {
            pane command="/home/jgatkinsn/.local/bin/claude" cwd="/home/jgatkinsn/Cloud-Drive/Jay/ObsidianNotes" size="50%" {
                start_suspended true
            }
            pane size="50%"
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="BGG_SUBS" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="vertical" {
            pane command="npm" cwd="/home/jgatkinsn/projects/bgg_sub_digest" size="50%" {
                args "exec" "@playwright/mcp@latest"
                start_suspended true
            }
            pane cwd="projects/bgg_sub_digest" size="50%"
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    new_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane cwd="/home/jgatkinsn"
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    swap_tiled_layout name="vertical" {
        tab max_panes=5 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane
                    pane {
                        children
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
        tab max_panes=8 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane {
                        children
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
        tab max_panes=12 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane {
                        children
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
    }
    swap_tiled_layout name="horizontal" {
        tab max_panes=4 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane
                pane
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
        tab max_panes=8 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane {
                    pane split_direction="vertical" {
                        children
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
        tab max_panes=12 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane {
                    pane split_direction="vertical" {
                        children
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
    }
    swap_tiled_layout name="stacked" {
        tab min_panes=5 {
            pane size=1 borderless=true {
                plugin location="zellij:tab-bar"
            }
            pane {
                pane split_direction="vertical" {
                    pane
                    pane stacked=true {
                        children
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="zellij:status-bar"
            }
        }
    }
    swap_floating_layout name="staggered" {
        floating_panes {
        }
    }
    swap_floating_layout name="enlarged" {
        floating_panes max_panes=10 {
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 1
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 2
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 3
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 4
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 5
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 6
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 7
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 8
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x "5%"
                y 9
            }
            pane cwd="/home/jgatkinsn" {
                height "90%"
                width "90%"
                x 10
                y 10
            }
        }
    }
    swap_floating_layout name="spread" {
        floating_panes max_panes=1 {
            pane cwd="/home/jgatkinsn" {
                x "50%"
                y "50%"
            }
        }
        floating_panes max_panes=2 {
            pane cwd="/home/jgatkinsn" {
                width "45%"
                x "1%"
                y "25%"
            }
            pane cwd="/home/jgatkinsn" {
                width "45%"
                x "50%"
                y "25%"
            }
        }
        floating_panes max_panes=3 {
            pane cwd="/home/jgatkinsn" {
                height "45%"
                width "45%"
                y "55%"
            }
            pane cwd="/home/jgatkinsn" {
                width "45%"
                x "1%"
                y "1%"
            }
            pane cwd="/home/jgatkinsn" {
                width "45%"
                x "50%"
                y "1%"
            }
        }
        floating_panes max_panes=4 {
            pane cwd="/home/jgatkinsn" {
                height "45%"
                width "45%"
                x "1%"
                y "55%"
            }
            pane cwd="/home/jgatkinsn" {
                height "45%"
                width "45%"
                x "50%"
                y "55%"
            }
            pane cwd="/home/jgatkinsn" {
                height "45%"
                width "45%"
                x "1%"
                y "1%"
            }
            pane cwd="/home/jgatkinsn" {
                height "45%"
                width "45%"
                x "50%"
                y "1%"
            }
        }
    }
}

