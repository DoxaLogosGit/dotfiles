# xonsh configuration — ~/.xonshrc
# https://xon.sh/

# PATH
$PATH = [$HOME + '/projects/Odin',
         $HOME + '/.local/bin',
         $HOME + '/.local/bin/yubico-authenticator',
         $HOME + '/projects/ols',
         $HOME + '/.cargo/bin',
         $HOME + '/.nvm',
         $HOME + '/.lmstudio/bin',
         $HOME + '/.bun/bin'] + list($PATH)

# Environment
$NVM_DIR     = $HOME + '/.nvm'
$ODIN_ROOT   = $HOME + '/projects/Odin'
$BUN_INSTALL = $HOME + '/.bun'
$EDITOR      = 'nvim'
$ENABLE_TOOL_SEARCH = 'true'
$TERM        = 'xterm-256color'

# Config completions
$XONSH_PROMPT_AUTO_SUGGEST = True
$AUTO_SUGGEST_IN_COMPLETION = True
$COMPLETIONS_CONFIRM = True
$COMPLETION_MODE = 'menu-complete'   # cycles through options on repeated Tab
$COMPLETIONS_MENU_ROWS = 5
$COMPLETION_IN_THREAD = True
$FUZZY_PATH_COMPLETION = True       # this is actually on by default, but confirm it
$SUBSEQUENCE_PATH_COMPLETIONS = True
$GLOB_SORTED = True          # keeps the prompt responsive

# FZF
$FZF_DEFAULT_COMMAND = 'fd --hidden --follow --exclude .git'
$FZF_DEFAULT_OPTS    = '--height 40% --layout=reverse --border --preview-window=right:60%:wrap'

# Aliases
aliases['ll']  = 'eza --icons=always --color=always --color-scale=all -l --git'
aliases['c']   = ['env', 'CLAUDE_CONFIG_DIR=' + $HOME + '/.claude',
                  $HOME + '/.local/bin/claude']
aliases['cw']  = ['env', 'CLAUDE_CONFIG_DIR=' + $HOME + '/.claude-work',
                  $HOME + '/.local/bin/claude']

# yazi — change directory on exit
def _y(*args):
    import os, subprocess, tempfile
    tmp = tempfile.mktemp(prefix='yazi-cwd.')
    subprocess.run(['yazi'] + list(args) + [f'--cwd-file={tmp}'])
    try:
        with open(tmp) as f:
            cwd = f.read().strip()
        if cwd and cwd != os.getcwd():
            os.chdir(cwd)
    except FileNotFoundError:
        pass
    finally:
        try:
            os.unlink(tmp)
        except OSError:
            pass
aliases['y'] = _y

# Atuin shell history
execx($(atuin init xonsh))

# Starship prompt
execx($(starship init xonsh))

# mise version manager
execx($(mise activate xonsh))

# zoxide (smarter cd)
execx($(zoxide init xonsh), glbs=globals())
