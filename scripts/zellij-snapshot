#!/usr/bin/env bash
#
# zellij-snapshot - rotating snapshots of Zellij session state
#
# Defends against partial-write corruption and lost tabs by maintaining
# a rotating history of session_info directories. Validates snapshots
# before keeping them so a bad snapshot never overwrites good history.
#
# Usage:
#   zellij-snapshot           # take a snapshot
#   zellij-snapshot --list    # list snapshots
#   zellij-snapshot --verify  # verify all existing snapshots
#

set -euo pipefail

# --- Configuration -----------------------------------------------------------

SESSION_DIR="${ZELLIJ_SESSION_DIR:-$HOME/.cache/zellij/contract_version_1/session_info}"
SNAPSHOT_ROOT="${ZELLIJ_SNAPSHOT_ROOT:-$HOME/.local/share/zellij-snapshots}"
KEEP="${ZELLIJ_SNAPSHOT_KEEP:-10}"
LAST_GOOD_LINK="$SNAPSHOT_ROOT/last-good"

# --- Helpers -----------------------------------------------------------------

log() { printf '[zellij-snapshot] %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

# Validate a snapshot directory. Returns 0 if usable, non-zero otherwise.
# A valid snapshot has at least one session_info/<name>/ subdirectory
# containing both session-layout.kdl and session-metadata.kdl, where
# the layout file is non-empty and parses as a structurally-plausible
# KDL document (contains at least one tab definition).
validate_snapshot() {
    local snap="$1"
    local sessions_dir="$snap/session_info"

    [[ -d "$sessions_dir" ]] || { log "validate: no session_info dir in $snap"; return 1; }

    local found_valid=0
    local session
    for session in "$sessions_dir"/*/; do
        [[ -d "$session" ]] || continue
        local layout="$session/session-layout.kdl"
        local metadata="$session/session-metadata.kdl"

        # Both files must exist (orphan = bad state, like blossoming-panda)
        [[ -f "$layout" && -f "$metadata" ]] || continue

        # Layout must be non-empty
        [[ -s "$layout" ]] || continue

        # Layout must contain at least one tab. KDL tab definitions
        # appear as `tab` or `tab name="..."` at varying indentation.
        # We're not parsing KDL properly, just sanity-checking.
        grep -qE '^\s*tab(\s|$)' "$layout" || continue

        found_valid=1
    done

    [[ $found_valid -eq 1 ]] || { log "validate: no valid sessions in $snap"; return 1; }
    return 0
}

# --- Subcommands -------------------------------------------------------------

cmd_snapshot() {
    [[ -d "$SESSION_DIR" ]] || die "session dir does not exist: $SESSION_DIR"

    mkdir -p "$SNAPSHOT_ROOT"

    local timestamp
    timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
    local target="$SNAPSHOT_ROOT/$timestamp"
    local partial="$target.partial"

    # Clean up any leftover partial from a previous failed run
    [[ -e "$partial" ]] && rm -rf "$partial"

    # Copy then rename, so we never leave a half-copied snapshot
    # visible under its final name. -a preserves timestamps/perms.
    cp -a "$SESSION_DIR" "$partial/session_info" 2>/dev/null || {
        mkdir -p "$partial"
        cp -a "$SESSION_DIR"/. "$partial/session_info/"
    }

    if ! validate_snapshot "$partial"; then
        log "snapshot $timestamp failed validation, discarding"
        rm -rf "$partial"
        return 1
    fi

    mv "$partial" "$target"
    log "snapshot $timestamp ok"

    # Update last-good symlink atomically via rename
    local tmp_link="$SNAPSHOT_ROOT/.last-good.tmp.$$"
    ln -sf "$timestamp" "$tmp_link"
    mv -T "$tmp_link" "$LAST_GOOD_LINK"

    # Prune old snapshots, keeping the most recent $KEEP valid ones
    # plus the symlink. We sort by name (timestamps are sortable).
    local -a snapshots
    mapfile -t snapshots < <(
        find "$SNAPSHOT_ROOT" -maxdepth 1 -mindepth 1 -type d \
            -not -name '.*' -printf '%f\n' | sort
    )

    local count=${#snapshots[@]}
    local to_remove=$(( count - KEEP ))
    if (( to_remove > 0 )); then
        local i
        for (( i = 0; i < to_remove; i++ )); do
            local victim="${snapshots[$i]}"
            log "pruning old snapshot $victim"
            rm -rf "${SNAPSHOT_ROOT:?}/$victim"
        done
    fi
}

cmd_list() {
    [[ -d "$SNAPSHOT_ROOT" ]] || { log "no snapshots yet"; return 0; }

    local last_good=""
    if [[ -L "$LAST_GOOD_LINK" ]]; then
        last_good="$(readlink "$LAST_GOOD_LINK")"
    fi

    local snap
    while IFS= read -r snap; do
        local marker=" "
        [[ "$snap" == "$last_good" ]] && marker="*"
        local sessions
        sessions=$(find "$SNAPSHOT_ROOT/$snap/session_info" \
            -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
        printf '%s %s  (%d sessions)\n' "$marker" "$snap" "$sessions"
    done < <(
        find "$SNAPSHOT_ROOT" -maxdepth 1 -mindepth 1 -type d \
            -not -name '.*' -printf '%f\n' | sort
    )

    echo
    echo "  (* = last-good)"
}

cmd_verify() {
    [[ -d "$SNAPSHOT_ROOT" ]] || { log "no snapshots yet"; return 0; }

    local ok=0 bad=0
    local snap
    while IFS= read -r snap; do
        local path="$SNAPSHOT_ROOT/$snap"
        if validate_snapshot "$path" >/dev/null 2>&1; then
            printf 'OK   %s\n' "$snap"
            ok=$(( ok + 1 ))
        else
            printf 'BAD  %s\n' "$snap"
            bad=$(( bad + 1 ))
        fi
    done < <(
        find "$SNAPSHOT_ROOT" -maxdepth 1 -mindepth 1 -type d \
            -not -name '.*' -printf '%f\n' | sort
    )

    echo
    printf 'Verified: %d ok, %d bad\n' "$ok" "$bad"
}

# --- Dispatch ----------------------------------------------------------------

case "${1:-snapshot}" in
    snapshot|"")    cmd_snapshot ;;
    --list|list)    cmd_list ;;
    --verify|verify) cmd_verify ;;
    -h|--help|help)
        cat <<EOF
zellij-snapshot - rotating snapshots of Zellij session state

Usage:
  zellij-snapshot              Take a snapshot (default)
  zellij-snapshot --list       List existing snapshots
  zellij-snapshot --verify     Validate all existing snapshots

Environment variables:
  ZELLIJ_SESSION_DIR    Source dir (default: ~/.cache/zellij/contract_version_1/session_info)
  ZELLIJ_SNAPSHOT_ROOT  Snapshot dir (default: ~/.local/share/zellij-snapshots)
  ZELLIJ_SNAPSHOT_KEEP  Snapshots to retain (default: 10)
EOF
        ;;
    *)
        die "unknown subcommand: $1 (try --help)"
        ;;
esac
