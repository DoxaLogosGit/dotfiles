#!/usr/bin/env bash
#
# zellij-restore - restore Zellij session state from a snapshot
#
# Usage:
#   zellij-restore                  # restore from last-good
#   zellij-restore <timestamp>      # restore from specific snapshot
#   zellij-restore --list           # show available snapshots (same as zellij-snapshot --list)
#
# Any running zellij sessions are killed automatically before restoring.

set -euo pipefail

SESSION_DIR="${ZELLIJ_SESSION_DIR:-$HOME/.cache/zellij/contract_version_1/session_info}"
SNAPSHOT_ROOT="${ZELLIJ_SNAPSHOT_ROOT:-$HOME/.local/share/zellij-snapshots}"
LAST_GOOD_LINK="$SNAPSHOT_ROOT/last-good"

log() { printf '[zellij-restore] %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

# Kill any running zellij sessions/server before restoring
kill_zellij_if_running() {
    local user="${USER:-$(id -un)}"
    if ! pgrep -u "$user" -x zellij >/dev/null 2>&1; then
        return 0
    fi
    log "zellij is running — killing sessions before restore"
    zellij kill-all-sessions --yes 2>/dev/null || true
    # Wait for the server process to exit (up to 5s)
    local i
    for (( i = 0; i < 10; i++ )); do
        pgrep -u "$user" -x zellij >/dev/null 2>&1 || return 0
        sleep 0.5
    done
    # Still running — force kill
    pkill -u "$user" -x zellij 2>/dev/null || true
    sleep 0.5
    pgrep -u "$user" -x zellij >/dev/null 2>&1 && die "could not stop zellij; kill it manually and retry"
    log "zellij stopped"
}

usage() {
    cat <<EOF
zellij-restore - restore Zellij session state from a snapshot

Usage:
  zellij-restore               Restore from last-good snapshot
  zellij-restore <timestamp>   Restore from a specific snapshot
  zellij-restore --list        Show available snapshots

The snapshot timestamp format is YYYYMMDDTHHMMSSZ (UTC), e.g.
20260515T213100Z. Use --list to see what's available.

Any running zellij sessions are killed automatically before restoring.
A backup of the current session_info is made before restore at
<session_dir>.pre-restore.<timestamp>
EOF
}

cmd_list() {
    exec zellij-snapshot --list
}

cmd_restore() {
    local snap_name="${1:-}"

    if [[ -z "$snap_name" ]]; then
        [[ -L "$LAST_GOOD_LINK" ]] || die "no last-good snapshot exists; specify one explicitly"
        snap_name="$(readlink "$LAST_GOOD_LINK")"
        log "using last-good: $snap_name"
    fi

    local snap_path="$SNAPSHOT_ROOT/$snap_name"
    [[ -d "$snap_path" ]] || die "snapshot not found: $snap_name"
    [[ -d "$snap_path/session_info" ]] || die "snapshot has no session_info: $snap_name"

    kill_zellij_if_running

    # Back up current state before clobbering
    if [[ -d "$SESSION_DIR" ]]; then
        local backup_stamp
        backup_stamp="$(date -u +%Y%m%dT%H%M%SZ)"
        local backup="${SESSION_DIR}.pre-restore.${backup_stamp}"
        log "backing up current state to $backup"
        mv "$SESSION_DIR" "$backup"
    fi

    mkdir -p "$(dirname "$SESSION_DIR")"
    cp -a "$snap_path/session_info" "$SESSION_DIR"
    log "restored from $snap_name"
    log "you can now start zellij and attach to your sessions"
}

case "${1:-}" in
    --list|list)        cmd_list ;;
    -h|--help|help)     usage ;;
    *)                  cmd_restore "${1:-}" ;;
esac
